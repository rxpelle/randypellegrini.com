      </form>
      <div id="email-capture-success" style="display:none">
        <p style="color: var(--teal); font-weight: 600;">You're in. Check your inbox for <em>The Edmund Fragments</em>.</p>
      </div>
    </div>

    <div style="text-align: center; margin-top: 32px;">
      <button class="button ghost" id="try-again">Read another cup</button>
    </div>
  </div>
</section>

<section class="section">
  <div class="article-body reveal" style="max-width: 720px; margin: 0 auto;">
    <h2>What is tasseography? The ancient art of reading coffee grounds</h2>
    <p>
      For centuries, practitioners have read the patterns left behind in cups of tea and coffee.
      Coffee grounds reading (also called tasseography or tasseomancy) interprets the shapes,
      symbols, and formations in your cup. The shapes aren't random &mdash; they're residue maps,
      traces of fluid dynamics that encode information about the conditions that created them.
    </p>
    <p>
      In <em>The Architecture of Survival</em> series, the defensive network has been reading patterns
      like these since the Bronze Age. Not in cups, but in civilizations &mdash; the faint signals
      that precede collapse, visible only to those trained to look.
    </p>
    <p>
      <em>The Genesis Protocol</em> is the second book in the series. When MIT geneticist Sarah Chen
      discovers that a centuries-old order is preparing to deploy an engineered bioweapon across
      47 cities, she has 72 hours to memorize everything &mdash; because the patterns she carries
      in her mind are the only backup system for four billion lives.
    </p>
    <div style="text-align: center; margin-top: 24px;">
      <a class="button" href="{{ site.amazonBook2Url }}" target="_blank" rel="noopener noreferrer">Get The Genesis Protocol &rarr;</a>
      <a class="button ghost" href="/books.html" style="margin-left: 12px;">Explore the series</a>
    </div>
  </div>
</section>
{% endblock %}

{% block pageScript %}
<script src="https://cdn.jsdelivr.net/npm/dompurify@3.2.4/dist/purify.min.js" integrity="sha384-eEu5CTj3qGvu9PdJuS+YlkNi7d2XxQROAFYOr59zgObtlcux1ae1Il3u7jvdCSWu" crossorigin="anonymous"></script>
<script>
(function() {
  // Config — update this URL after deploying the Cloudflare Worker
  var WORKER_URL = 'https://grounds-reader.randypellegrini.workers.dev';

  // Elements
  var form = document.getElementById('grounds-form');
  var formCard = document.getElementById('grounds-form-card');
  var uploadArea = document.getElementById('upload-area');
  var fileInput = document.getElementById('cup-image');
  var placeholder = document.getElementById('upload-placeholder');
  var preview = document.getElementById('image-preview');
  var submitBtn = document.getElementById('grounds-submit');
  var buttonText = document.getElementById('grounds-button-text');
  var loadingEl = document.getElementById('grounds-loading');
  var resultEl = document.getElementById('reading-result');
  var readingText = document.getElementById('reading-text');
  var shareCopy = document.getElementById('share-copy');
  var shareX = document.getElementById('share-x');
  var shareNative = document.getElementById('share-native');
  var tryAgain = document.getElementById('try-again');

  // Email capture elements
  var emailCapture = document.getElementById('email-capture');
  var emailCaptureForm = document.getElementById('email-capture-form');
  var emailCaptureSuccess = document.getElementById('email-capture-success');
  var captureEmail = document.getElementById('capture-email');
  var captureName = document.getElementById('capture-name');
  var captureSubmit = document.getElementById('capture-submit');
  var captureButtonText = document.getElementById('capture-button-text');

  var currentReadingUrl = '';
  var currentReadingId = '';

  // Check for shared reading on page load
  var params = new URLSearchParams(window.location.search);
  var sharedId = params.get('reading');
  if (sharedId) {
    loadSharedReading(sharedId);
  }

  // Show native share button if supported
  if (navigator.share) {
    shareNative.style.display = '';
  }

  // File selection
  fileInput.addEventListener('change', function() {
    if (fileInput.files && fileInput.files[0]) {
      showPreview(fileInput.files[0]);
    }
  });

  // Drag and drop
  uploadArea.addEventListener('dragover', function(e) {
    e.preventDefault();
    uploadArea.classList.add('dragover');
  });
  uploadArea.addEventListener('dragleave', function() {
    uploadArea.classList.remove('dragover');
  });
  uploadArea.addEventListener('drop', function(e) {
    e.preventDefault();
    uploadArea.classList.remove('dragover');
    if (e.dataTransfer.files && e.dataTransfer.files[0]) {
      fileInput.files = e.dataTransfer.files;
      showPreview(e.dataTransfer.files[0]);
    }
  });

  function showPreview(file) {
    var reader = new FileReader();
    reader.onload = function(e) {
      preview.src = e.target.result;
      preview.style.display = 'block';
      placeholder.style.display = 'none';
    };
    reader.readAsDataURL(file);
  }

  // Form submit
  form.addEventListener('submit', function(e) {
    e.preventDefault();

    if (!fileInput.files || !fileInput.files[0]) {
      alert('Please upload a photo of your cup first.');
      return;
    }

    if (fileInput.files[0].size > 5 * 1024 * 1024) {
      alert('Image must be under 5MB.');
      return;
    }

    var formData = new FormData();
    formData.append('image', fileInput.files[0]);

    showLoading();

    fetch(WORKER_URL + '/api/read-grounds', {
      method: 'POST',
      body: formData
    })
    .then(function(r) {
      if (r.status === 429) {
        return r.json().then(function(d) { throw new Error(d.error); });
      }
      if (!r.ok) {
        return r.json().then(function(d) { throw new Error(d.error || 'Something went wrong'); });
      }
      return r.json();
    })
    .then(function(data) {
      displayReading(data.id, data.reading, false);
      gtag('event', 'grounds_reading_received', { page_location: window.location.href });
    })
    .catch(function(err) {
      hideLoading();
      formCard.style.display = '';
      alert(err.message || 'Something went wrong. Please try again.');
    });

    gtag('event', 'grounds_upload', { page_location: window.location.href });
  });

  function showLoading() {
    formCard.style.display = 'none';
    resultEl.style.display = 'none';
    loadingEl.style.display = 'block';
  }

  function hideLoading() {
    loadingEl.style.display = 'none';
  }

  function displayReading(id, reading, isShared) {
    hideLoading();

    // Store reading ID for email subscription
    currentReadingId = id;

    // Convert markdown bold/italic to HTML
    var html = reading
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.+?)\*/g, '<em class="protocol-fragment">$1</em>')
      .replace(/\n\n/g, '</p><p>')
      .replace(/\n/g, '<br>');
    html = '<p>' + html + '</p>';

    readingText.innerHTML = DOMPurify.sanitize(html, { ALLOWED_TAGS: ['p', 'br', 'strong', 'em'], ALLOWED_ATTR: ['class'] });
    resultEl.style.display = 'block';

    // Show email capture for new readings (not shared links)
    if (!isShared) {
      emailCapture.style.display = '';
      emailCaptureForm.style.display = '';
      emailCaptureSuccess.style.display = 'none';
    }

    // Update URL for sharing
    var readingUrl = window.location.origin + window.location.pathname + '?reading=' + id;
    currentReadingUrl = readingUrl;
    history.pushState(null, '', readingUrl);

    // Set up share links
    var shareText = 'I just had my coffee grounds read. The patterns revealed something interesting...';
    shareX.href = 'https://x.com/intent/tweet?text=' + encodeURIComponent(shareText) + '&url=' + encodeURIComponent(readingUrl);
  }

  // Share handlers
  shareCopy.addEventListener('click', function() {
    navigator.clipboard.writeText(currentReadingUrl).then(function() {
      shareCopy.textContent = 'Copied!';
      setTimeout(function() { shareCopy.textContent = 'Copy Link'; }, 2000);
    });
    gtag('event', 'grounds_shared', { method: 'copy', page_location: window.location.href });
  });

  shareNative.addEventListener('click', function() {
    navigator.share({
      title: 'My Coffee Grounds Reading',
      text: 'I just had my coffee grounds read. The patterns revealed something interesting...',
      url: currentReadingUrl
    });
    gtag('event', 'grounds_shared', { method: 'native', page_location: window.location.href });
  });

  // Email capture form
  emailCaptureForm.addEventListener('submit', function(e) {
    e.preventDefault();

    var email = captureEmail.value;
    var firstName = captureName.value;

    if (!email) {
      alert('Please enter your email address.');
      return;
    }

    captureSubmit.disabled = true;
    captureButtonText.textContent = 'Subscribing...';

    fetch(WORKER_URL + '/api/reading/' + currentReadingId + '/subscribe', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: email, firstName: firstName })
    })
    .then(function(r) {
      if (!r.ok) {
        return r.json().then(function(d) { throw new Error(d.error || 'Something went wrong'); });
      }
      return r.json();
    })
    .then(function() {
      emailCaptureForm.style.display = 'none';
      emailCaptureSuccess.style.display = '';
      gtag('event', 'grounds_email_captured', { page_location: window.location.href });
    })
    .catch(function(err) {
      captureSubmit.disabled = false;
      captureButtonText.textContent = 'Send me the free story';
      alert(err.message || 'Something went wrong. Please try again.');
    });
  });

  // Try again
  tryAgain.addEventListener('click', function() {
    resultEl.style.display = 'none';
    formCard.style.display = '';
    preview.style.display = 'none';
    placeholder.style.display = '';
    fileInput.value = '';
    // Reset email capture
    emailCapture.style.display = 'none';
    emailCaptureForm.style.display = '';
    emailCaptureSuccess.style.display = 'none';
    captureEmail.value = '';
    captureName.value = '';
    captureSubmit.disabled = false;
    captureButtonText.textContent = 'Send me the free story';
    currentReadingId = '';
    history.pushState(null, '', window.location.pathname);
  });

  // Load shared reading
  function loadSharedReading(id) {
    formCard.style.display = 'none';
    showLoading();

    fetch(WORKER_URL + '/api/reading/' + id)
      .then(function(r) {
        if (!r.ok) throw new Error('Reading not found');
        return r.json();
      })
      .then(function(data) {
        displayReading(data.id, data.reading, true);
      })
      .catch(function() {
        hideLoading();
        formCard.style.display = '';
      });
  }
})();
</script>
{% endblock %}
