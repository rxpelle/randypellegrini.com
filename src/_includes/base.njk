<!doctype html>
<html lang="en">
  <head>
    <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.gaId }}"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      var loc = window.location.pathname;
      if (loc.endsWith('.html')) { loc = loc.replace(/\.html$/, '/'); }
      gtag('config', '{{ site.gaId }}', { page_path: loc });
    </script>
    <meta charset="utf-8" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://www.google-analytics.com https://analytics.google.com https://*.googletagmanager.com https://script.google.com https://script.googleusercontent.com https://grounds-reader.randypellegrini.workers.dev; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self' https://script.google.com;" />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if fullTitle %}{{ fullTitle }}{% else %}{{ title }} | Randy Pellegrini{% endif %}</title>
    {% if description %}<meta name="description" content="{{ description }}" />{% endif %}
    {%- set _ogTitle = ogTitle or title or fullTitle -%}
    {%- set _ogDesc = ogDescription or description -%}
    <meta property="og:title" content="{{ _ogTitle }}" />
    <meta property="og:description" content="{{ _ogDesc }}" />
    <meta property="og:type" content="{{ ogType | default('website') }}" />
    <meta property="og:url" content="{{ ogUrl | default(site.url + page.url) }}" />
    <meta property="og:site_name" content="Randy Pellegrini" />
    <meta property="og:image" content="{{ ogImage | default(site.url + '/assets/book-cover.png') }}" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@rxpelle" />
    <meta name="twitter:creator" content="@rxpelle" />
    <meta name="twitter:title" content="{{ _ogTitle }}" />
    <meta name="twitter:description" content="{{ _ogDesc }}" />
    <meta name="twitter:image" content="{{ ogImage | default(site.url + '/assets/book-cover.png') }}" />
    <link rel="canonical" href="{{ ogUrl | default(site.url + page.url) }}" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=Public+Sans:wght@300;400;600&display=swap" rel="stylesheet" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="stylesheet" href="/styles.css" />
    <link rel="alternate" type="application/atom+xml" title="Randy Pellegrini" href="/feed.xml" />
    {% block pageStyles %}{% endblock %}
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <div class="page">
      {% include "header.njk" %}
      <div class="site-banner" id="site-banner">
        <div class="site-banner-inner">
          <span class="site-banner-text">Get a <strong>free story</strong> + series updates</span>
          <form class="site-banner-form" data-newsletter="true">
            <label class="sr-only" for="banner-email">Email address</label>
            <input id="banner-email" name="email" type="email" placeholder="you@email.com" required aria-label="Email address" />
            <button type="submit"><span>Subscribe</span></button>
          </form>
          <button class="site-banner-close" id="banner-close" aria-label="Close banner">&times;</button>
        </div>
      </div>
      <main id="{{ mainId | default('main-content') }}">
        {% block content %}{{ content | safe }}{% endblock %}
      </main>
      {% include "footer.njk" %}
    </div>
    <script src="/scripts.js"></script>
    <script src="/amazon-localize.js"></script>
    <script src="/analytics.js"></script>
    {% block pageScript %}{% endblock %}
  </body>
</html>
