---
layout: base.njk
---
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ title | dump | safe }},
  "description": {{ description | dump | safe }},{% if date %}
  "datePublished": "{{ date | isoDate }}",{% endif %}
  "image": "{{ ogImage | default(site.url + '/assets/book-cover.png') }}",
  "wordCount": "{{ content | wordCount }}",
  "author": {
    "@type": "Person",
    "name": "Randy Pellegrini",
    "url": "https://randypellegrini.com",
    "image": "https://randypellegrini.com/images/randypellegrini.jpg"
  },
  "publisher": {
    "@type": "Person",
    "name": "Randy Pellegrini"
  },
  "url": "{{ ogUrl | default(site.url + page.url) }}",
  "mainEntityOfPage": "{{ ogUrl | default(site.url + page.url) }}",
  "isPartOf": {
    "@type": "Blog",
    "name": "The Architecture of Survival Blog",
    "url": "https://randypellegrini.com/blog.html"
  }
}
</script>
<div class="article-container">
  <div class="article-header reveal">
    <p class="eyebrow">{{ bookTag }} &mdash; Essay {{ number }} of {{ collections.blog | length }}</p>
    <h1>{{ heading | default(title) | safe }}</h1>
    <p class="article-meta">By Randy Pellegrini{% if date %} · <time datetime="{{ date | isoDate }}">{{ date | readableDate }}</time>{% endif %}</p>
  </div>

  <div class="article-body reveal delay-1">
    {{ content | safe }}
  </div>

  <div class="article-cta reveal delay-2">
    {%- if bookTag == "Book 2: The Genesis Protocol" %}
    <h3>{{ ctaTitle | default("Read The Genesis Protocol") }}</h3>
    <p>{{ ctaText | safe }}</p>
    <a class="button" href="{{ site.amazonBook2Url }}" target="_blank" rel="noopener noreferrer">Get Book 2 &rarr;</a>
    {%- else %}
    <h3>{{ ctaTitle | default("Read The Aethelred Cipher") }}</h3>
    <p>{{ ctaText | safe }}</p>
    <a class="button" href="{{ ctaButtonUrl | default(site.amazonUrl) }}" target="_blank" rel="noopener noreferrer">{{ ctaButtonText | default("Get your copy") }} &rarr;</a>
    {%- endif %}
  </div>

  <div class="grounds-blog-cta reveal delay-2">
    <a href="/read-your-grounds.html" class="grounds-blog-cta-link">
      <span class="grounds-blog-cta-icon">&#9752;</span>
      <span>
        <strong>What do your coffee grounds reveal?</strong>
        <span class="grounds-blog-cta-sub">Upload a photo of your cup and receive a free AI-powered tasseography reading.</span>
      </span>
      <span class="grounds-blog-cta-arrow">&rarr;</span>
    </a>
  </div>

  {%- set _related = [] -%}
  {%- for post in collections.blog | reverse -%}
    {%- if post.data.bookTag == bookTag and post.url != page.url and _related.length < 3 -%}
      {{ "" if _related.push(post) }}
    {%- endif -%}
  {%- endfor -%}
  {%- if _related.length > 0 %}
  <div class="related-essays reveal delay-2">
    <h3>More from {{ bookTag }}</h3>
    <div class="related-grid">
      {%- for post in _related %}
      <a href="{{ post.url }}" class="related-card">
        <span class="related-number">{{ post.data.number | padStart(2) }}</span>
        <strong>{{ post.data.title }}</strong>
        <span class="related-excerpt">{{ post.data.excerpt | truncate(80) }}</span>
      </a>
      {%- endfor %}
    </div>
    <a href="/blog.html" class="related-all">View all essays &rarr;</a>
  </div>
  {%- endif %}

  <div class="article-nav">
    {% if prevPost %}<a href="{{ prevPost }}">&larr; {{ prevTitle }}</a>{% endif %}
    {% if nextPost %}<a href="{{ nextPost }}">{{ nextTitle }} &rarr;</a>{% else %}<a href="/blog.html">All posts &rarr;</a>{% endif %}
  </div>
</div>
